{
  "cli": {
    "appVersionSource": "local",
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_APP_SCHEME": "oyanomoshimo",
        "EXPO_PUBLIC_WEB_BASE_URL": "https://oyano-moshimo-navi.vercel.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_APP_SCHEME": "oyanomoshimo",
        "EXPO_PUBLIC_WEB_BASE_URL": "https://oyano-moshimo-navi.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_APP_SCHEME": "oyanomoshimo",
        "EXPO_PUBLIC_WEB_BASE_URL": "https://oyano-moshimo-navi.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
