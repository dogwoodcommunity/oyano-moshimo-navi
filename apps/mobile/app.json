{
  "expo": {
    "name": "親のもしもナビ",
    "slug": "oyano-moshimo-navi",
    "scheme": "oyanomoshimo",
    "version": "0.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f7f1"
    },
    "ios": {
      "bundleIdentifier": "jp.beech.oyanomoshimo",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "実家や書類の保管場所を家族で確認するために写真を登録します。",
        "NSPhotoLibraryUsageDescription": "実家や書類の保管場所を家族で確認するために写真を選択します。",
        "NSUserNotificationsUsageDescription": "期限が近い手続きや月1回の状況確認をお知らせします。"
      }
    },
    "android": {
      "package": "jp.beech.oyanomoshimo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#276447"
      },
      "permissions": ["POST_NOTIFICATIONS"]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#276447"
    },
    "plugins": ["expo-router", "expo-notifications"],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
