{
  "name": "oyano-moshimo-navi-v0-3",
  "private": true,
  "version": "0.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web run dev",
    "dev:web:lan": "pnpm --dir apps/web exec next dev -H 0.0.0.0 -p 3000",
    "dev:mobile": "pnpm --filter mobile run start",
    "doctor:local": "node scripts/local-doctor.mjs",
    "lint": "pnpm --filter web run lint",
    "smoke:web": "node scripts/smoke-web.mjs",
    "typecheck": "pnpm --filter web run typecheck && pnpm --filter mobile run typecheck"
  },
  "devDependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
